# App variables (required)
BASE_URL='YOUR BASE URL FOR YOUR APP. E.G USE NGROK TO FORWARD PORT 3000'
PORT=3000

# Database variables
MONGO_URI='mongodb://localhost:27017/paygate || Database of your choice'

# PayGate variables (required), for demo purposes remove the options below
PAYGATE_URL='https://secure.paygate.co.za'
PAYGATE_ID='10011072130 || Your PayGate ID'
PAYGATE_KEY='secret || Your PayGate Key'

# PayWeb3 credentials (optional, defaults to sandbox test credentials)
# PAYWEB_ID='10011072130'
# PAYWEB_KEY='secret'

# PaySubs credentials (optional, defaults to sandbox test credentials)
# PAYSUBS_URL='https://www.paygate.co.za/paysubs/process.trans'
# PAYSUBS_ID='10011072130'
# PAYSUBS_KEY='secret'

# SMTP (optional)
SMTP_HOST='your-smtp-host'
SMTP_PORT=587
SMTP_USERNAME='your-smtp-username'
SMTP_PASSWORD='your-smtp-password'
EMAIL_FROM='Your Name <email@example.com>'